# Core
# Local development may use json. Production must use postgres.
STORE_BACKEND=json
# web = HTTP app only, worker = background jobs only, all = local development only
PROCESS_ROLE=all
DATABASE_URL=
DATABASE_SSL=false
PORT=8080
APP_BASE_URL=http://localhost:8080
DATA_DIR=./data
SCREENSHOT_DIR=./data/screenshots
# PostgreSQL deployments copy screenshots into shared artifact storage for separate services.
ARTIFACT_MAX_BYTES=6291456
ARTIFACT_RETENTION_DAYS=90
ARTIFACT_DELETE_LOCAL_AFTER_UPLOAD=true
ADMIN_TOKEN=change-this-long-random-string
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-characters
UNSUBSCRIBE_SECRET=replace-with-another-long-random-secret
CHROMIUM_PATH=

# Durable worker queue
QUEUE_CONCURRENCY=2
QUEUE_POLL_MS=1000
QUEUE_MAX_ATTEMPTS=5
QUEUE_RETRY_BASE_MS=30000
QUEUE_RETRY_MAX_MS=3600000
QUEUE_LOCK_TIMEOUT_MS=1200000
QUEUE_JOB_HEARTBEAT_MS=15000
WORKER_HEARTBEAT_MS=15000
WORKER_STALE_MS=90000
QUEUE_MAX_RUNTIME_MS=900000

# Persistent worker
AUTOPILOT_ENABLED=false
MAX_BATCH_SIZE=25
CRAWL_CONCURRENCY=2
CRAWL_DELAY_MS=500
CRAWL_MIN_DOMAIN_GAP_MS=1500
MAX_PAGES_PER_SITE=5
CRAWL_TIMEOUT_MS=25000
CRAWL_MAX_ATTEMPTS=3
CRAWL_MIN_TEXT_LENGTH=80
CRAWL_MIN_QUALITY_SCORE=60
ALLOW_LOCAL_FIXTURES=false

# Unattended outbound safety. Keep disabled and dry-run true until launch review.
OUTBOUND_PROVIDER=test
OUTBOUND_ENABLED=false
OUTBOUND_DRY_RUN=true
# Independent production approval. Never enable during tests or initial setup.
OUTBOUND_LIVE_SEND_APPROVED=false
# Comma-separated country names or ISO codes. Campaigns must also explicitly allow each country.
OUTBOUND_ALLOWED_COUNTRIES=
DEFAULT_DAILY_CAP_A=20
DEFAULT_DAILY_CAP_B=20
OUTBOUND_HOURLY_CAP_A=5
OUTBOUND_HOURLY_CAP_B=5
OUTBOUND_MIN_GAP_SECONDS=90
OUTBOUND_MAX_GAP_JITTER_SECONDS=90
OUTBOUND_BUSINESS_HOUR_START=9
OUTBOUND_BUSINESS_HOUR_END=17
OUTBOUND_MIN_EVIDENCE_CONFIDENCE=0.75
OUTBOUND_HARD_BOUNCE_PAUSE_THRESHOLD=2
OUTBOUND_COMPLAINT_PAUSE_THRESHOLD=1
OUTBOUND_FAILURE_PAUSE_THRESHOLD=3
OUTBOUND_PROCESS_BATCH_SIZE=10
REPLY_POLL_MINUTES=10

# AI: rules, anthropic, or openai
AI_PROVIDER=rules
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional contact discovery / verification
HUNTER_API_KEY=

# Optional Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/google/callback

# Sender identity
SENDER_NAME=Mohamed Wessam
SENDER_COMPANY=UberBond
BUSINESS_ADDRESS=Add your valid postal business address before any commercial email

# Public 24/7 audit funnel
PUBLIC_AUDIT_ENABLED=true
PUBLIC_RATE_LIMIT_PER_HOUR=8
FREE_REPORT_FINDINGS=1
FULL_AUDIT_PRICE_USD=49
STRATEGY_AUDIT_PRICE_USD=299
MONITORING_PRICE_USD=99
IMPLEMENTATION_FROM_USD=1000
BOOKING_URL=
AUTO_EMAIL_REPORTS=false
REPORT_DELIVERY_INBOX=B

# Hosted checkout links. Lemon Squeezy works with the built-in webhook adapter.
PAYMENT_PROVIDER=links
FULL_AUDIT_CHECKOUT_URL=
STRATEGY_AUDIT_CHECKOUT_URL=
MONITORING_CHECKOUT_URL=
LEMONSQUEEZY_WEBHOOK_SECRET=
ALLOW_TEST_PAYMENT_UNLOCK=false

# Recurring monitoring
MONITORING_INTERVAL_DAYS=30
MONITORING_BATCH_SIZE=10

# Automatic public business discovery through OpenStreetMap Overpass
# Keep dry-run on until the preview is relevant. BBOX format: south,west,north,east.
DISCOVERY_ENABLED=false
DISCOVERY_DRY_RUN=true
DISCOVERY_CAMPAIGN_ID=
DISCOVERY_BBOX=
DISCOVERY_CATEGORIES=clinic,dentist,medical
DISCOVERY_COUNTRY=
DISCOVERY_CITY=
DISCOVERY_DAILY_CAP=100
DISCOVERY_BATCHES_PER_RUN=1
DISCOVERY_MAX_CAMPAIGNS_PER_RUN=10
DISCOVERY_RUN_EVERY_HOURS=24
DISCOVERY_TIMEOUT_MS=30000
DISCOVERY_MAX_BBOX_SPAN=5
DISCOVERY_EXCLUDED_DOMAINS=uberbondd-lite-private.vercel.app,uberbondd.vercel.app
DISCOVERY_OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
DISCOVERY_USER_AGENT=UberBondRevenueEngine/1.4 (+public business discovery; contact via site)
