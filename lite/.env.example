# Cash Engine Lite — environment variables
# Copy the values you need into Vercel Project Settings → Environment Variables
# and into GitHub repo Settings → Secrets and variables → Actions.
# See /LITE_ENV_CHECKLIST.md for the exact table of what goes where.

# Required. Neon pooled connection string (Settings → Connection Details → "Pooled connection").
DATABASE_URL=postgres://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional. Without these, leads are still stored in Postgres and printed in the
# GitHub Actions log every run — nothing is lost, you just check the log instead of email.
RESEND_API_KEY=
OWNER_EMAIL=
LITE_EMAIL_FROM="UberBond Lite <onboarding@resend.dev>"

# Optional. Salt used to hash visitor IPs for rate limiting. Any long random string works.
LITE_HASH_SALT=change-me-to-a-random-string
